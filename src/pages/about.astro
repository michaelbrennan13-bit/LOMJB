---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../consts';

const title = 'About Michael J. Brennan | Fort Bend & Houston Attorney';
const description =
  'Michael J. Brennan is a Houston-area attorney and former defense-side litigator who now represents plaintiffs, serving Fort Bend County and Greater Houston. Full-service practice led by personal injury. State Bar of Texas No. 24125746.';
---

<Layout title={title} description={description} path="/about">
  <!-- Intro -->
  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <p class="eyebrow">About the Firm</p>
      <span class="gold-rule mt-4"></span>
      <h1 class="mt-5 max-w-3xl text-4xl font-bold text-navy md:text-5xl">
        A solo Texas attorney who works your case personally.
      </h1>

      <div class="mt-12 grid gap-12 md:grid-cols-[300px_1fr] md:gap-16">
        <!-- Framed headshot with gold rule -->
        <div class="md:sticky md:top-28 md:self-start">
          <figure class="border border-warmgrey p-3">
            <div class="border-2 border-gold p-1">
              <img
                src="/assets/headshot.jpg"
                width="590"
                height="590"
                alt={`Portrait of ${SITE.attorney}, attorney and founder of ${SITE.name}`}
                class="aspect-square w-full object-cover"
                loading="eager"
              />
            </div>
            <figcaption class="mt-3 text-center">
              <span class="block font-display text-base tracking-wide text-burgundy">
                {SITE.attorney}
              </span>
              <span class="mt-1 block text-xs uppercase tracking-[0.18em] text-charcoal/60">
                Attorney
              </span>
            </figcaption>
          </figure>
        </div>

        <!-- Bio scaffold + credentials -->
        <div>
          <h2 class="text-2xl font-semibold text-navy">Biography</h2>
          <span class="gold-rule mt-3"></span>

          <!-- Bio drawn from the firm bio (Firm Bio.docx). Compliant wording:
               "focuses on," "handles," "practices in"; never specialist/expert/
               specializing/certified (README §5). -->
          <div class="mt-6 space-y-5 leading-relaxed text-charcoal/90">
            <p>
              For years, Michael J. Brennan worked on complex personal injury
              and wrongful death cases across Texas, much of it defending these
              claims, from industrial accidents along the Gulf Coast to highway
              collisions in small East Texas towns. That courtroom experience
              now goes to work for the individuals and families he represents.
            </p>
            <p>
              Michael founded the <strong>Law Office of Michael J. Brennan,
              PLLC</strong> to serve clients on his own terms, bringing careful
              strategy and a close reading of the facts to every matter he takes
              on. As a solo practitioner serving <strong>Fort Bend County and
              Greater Houston</strong>, he gives clients direct, personal
              attention at every stage.
            </p>
            <p>
              His experience spans a wide range of serious matters, from
              interstate trucking and commercial fleet cases to oilfield and
              industrial workplace accidents and premises liability disputes.
              That experience shapes the clear, well-prepared approach he brings
              to every case today.
            </p>
            <p>
              Born and raised in the Houston area, Michael is a member of
              Memorial Drive Presbyterian Church and is grateful to serve the
              community he grew up in. He built his practice on a simple belief:
              people facing a legal problem deserve a lawyer who treats them
              kindly, explains things clearly, and makes a stressful process
              easier. Outside the office, he enjoys walking his dogs along the
              Hershey Trails, golfing, and reading.
            </p>
          </div>

          <!-- Credentials -->
          <h2 class="mt-12 text-2xl font-semibold text-navy">Credentials</h2>
          <span class="gold-rule mt-3"></span>
          <dl class="mt-6 divide-y divide-warmgrey">
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Education</dt>
              <dd class="text-charcoal/90">
                Baylor University (BBA)<br />
                Texas A&amp;M University School of Law (JD)
              </dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Court admissions</dt>
              <dd class="text-charcoal/90">
                All Texas state courts; U.S. District Courts for the Southern,
                Eastern, and Western Districts of Texas.
              </dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Bar number</dt>
              <dd class="text-charcoal/90">
                State Bar of Texas No. {SITE.barNumber}
              </dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Memberships</dt>
              <dd class="text-charcoal/90">
                Houston Young Lawyers Association; Houston Trial Lawyers
                Association; Texas Trial Lawyers Association (Lead Academy 2026).
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach / values -->
  <section class="bg-warmgrey">
    <div class="container-page py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">Approach &amp; Values</p>
        <span class="gold-rule mt-4"></span>
        <h2 class="mt-5 text-3xl font-bold text-navy md:text-4xl">
          How the firm works with you.
        </h2>
      </div>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          [
            {
              t: 'Direct access',
              d: 'You deal with your attorney throughout, not a rotating cast of case managers or intake staff.',
            },
            {
              t: 'Candid advice',
              d: 'Straight answers about your options and the realistic path ahead, even when the news is not what you hoped.',
            },
            {
              t: 'Local roots',
              d: 'Deep familiarity with Fort Bend and Greater Houston, and the courts where these matters are decided.',
            },
          ].map((v) => (
            <div class="border-t-2 border-gold bg-white p-8">
              <h3 class="text-xl font-semibold text-navy">{v.t}</h3>
              <p class="mt-3 leading-relaxed text-charcoal/85">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-white">
    <div class="container-page flex flex-col items-start gap-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="max-w-2xl text-3xl font-bold text-white md:text-4xl">
        Have a question about your situation? Let’s talk.
      </h2>
      <a href="/contact" class="btn btn-on-dark shrink-0">Free Consultation</a>
    </div>
  </section>
</Layout>
