---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../consts';

const title = 'About Michael J. Brennan | Fort Bend & Houston Attorney';
const description =
  'Michael J. Brennan is a Texas attorney serving Fort Bend County and Greater Houston, focusing on personal injury and general-practice matters. Licensed in Texas, Bar No. 24125746.';
---

<Layout title={title} description={description} path="/about">
  <!-- Intro -->
  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <p class="eyebrow">About the Firm</p>
      <span class="gold-rule mt-4"></span>
      <h1 class="mt-5 max-w-3xl text-4xl font-bold text-navy md:text-5xl">
        A solo Texas attorney who works your case personally.
      </h1>

      <div class="mt-12 grid gap-12 md:grid-cols-[300px_1fr] md:gap-16">
        <!-- Framed headshot with gold rule -->
        <div class="md:sticky md:top-28 md:self-start">
          <figure class="border border-warmgrey p-3">
            <div class="border-2 border-gold p-1">
              <img
                src="/assets/headshot-placeholder.svg"
                width="480"
                height="600"
                alt={`Portrait of ${SITE.attorney} (placeholder — professional photo to be added)`}
                class="w-full"
              />
            </div>
            <figcaption class="mt-3 text-center font-display text-sm tracking-wide text-burgundy">
              {SITE.attorney}
            </figcaption>
          </figure>
        </div>

        <!-- Bio scaffold + credentials -->
        <div>
          <h2 class="text-2xl font-semibold text-navy">Biography</h2>
          <span class="gold-rule mt-3"></span>

          <!-- PLACEHOLDER bio — replace bracketed blanks. Keep language compliant:
               use "focuses on," "handles," "practices in" (never specialist/expert/
               specializing/certified). -->
          <div class="mt-6 space-y-5 leading-relaxed text-charcoal/90">
            <p>
              <span class="rounded bg-gold/20 px-1">[PLACEHOLDER]</span> Michael
              J. Brennan is the founder of the Law Office of Michael J. Brennan,
              PLLC, a Texas firm that focuses on personal injury and handles a
              range of general-practice matters for individuals and families in
              <strong>Fort Bend County and Greater Houston</strong>. He earned
              his <span class="rounded bg-gold/20 px-1">[degree]</span> from
              <span class="rounded bg-gold/20 px-1">[law school]</span> in
              <span class="rounded bg-gold/20 px-1">[year]</span> and was
              admitted to practice in Texas in
              <span class="rounded bg-gold/20 px-1">[admission year]</span>.
            </p>
            <p>
              <span class="rounded bg-gold/20 px-1">[PLACEHOLDER]</span> Before
              founding the firm, Michael
              <span class="rounded bg-gold/20 px-1"
                >[background — prior roles, relevant experience; note experience
                on both sides of the docket if accurate — confirm]</span
              >. He practices in
              <span class="rounded bg-gold/20 px-1"
                >[areas of focus]</span
              > and is committed to direct client communication, candid advice,
              and straightforward fees.
            </p>
          </div>

          <!-- Credentials -->
          <h2 class="mt-12 text-2xl font-semibold text-navy">Credentials</h2>
          <span class="gold-rule mt-3"></span>
          <dl class="mt-6 divide-y divide-warmgrey">
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Education</dt>
              <dd class="text-charcoal/90">
                <span class="rounded bg-gold/20 px-1"
                  >[ law school, degree, year ]</span
                >
              </dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Admission</dt>
              <dd class="text-charcoal/90">
                Licensed in Texas — State Bar No. {SITE.barNumber}
              </dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-4 sm:grid-cols-[180px_1fr]">
              <dt class="font-semibold text-navy">Areas of focus</dt>
              <dd class="text-charcoal/90">
                Personal injury, wrongful death, estate planning &amp; wills,
                civil litigation, and landlord–tenant / real estate.
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach / values -->
  <section class="bg-warmgrey">
    <div class="container-page py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">Approach &amp; Values</p>
        <span class="gold-rule mt-4"></span>
        <h2 class="mt-5 text-3xl font-bold text-navy md:text-4xl">
          How the firm works with you.
        </h2>
      </div>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          [
            {
              t: 'Direct access',
              d: 'You deal with your attorney throughout — not a rotating cast of case managers or intake staff.',
            },
            {
              t: 'Candid advice',
              d: 'Straight answers about your options and the realistic path ahead, even when the news is not what you hoped.',
            },
            {
              t: 'Local roots',
              d: 'Deep familiarity with Fort Bend and Greater Houston, and the courts where these matters are decided.',
            },
          ].map((v) => (
            <div class="border-t-2 border-gold bg-white p-8">
              <h3 class="text-xl font-semibold text-navy">{v.t}</h3>
              <p class="mt-3 leading-relaxed text-charcoal/85">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-white">
    <div class="container-page flex flex-col items-start gap-6 py-16 md:flex-row md:items-center md:justify-between">
      <h2 class="max-w-2xl text-3xl font-bold text-white md:text-4xl">
        Have a question about your situation? Let’s talk.
      </h2>
      <a href="/contact" class="btn btn-on-dark shrink-0">Free Consultation</a>
    </div>
  </section>
</Layout>
