---
import type { IconName } from '../data/practices';

interface Props {
  name: IconName;
  class?: string;
}
const { name, class: className = 'h-9 w-9' } = Astro.props;

// Gold-line (stroke) icons — one shared 24×24 grid, 1.6 stroke, round joins.
// Decorative; the card heading conveys meaning. Keep this stroke style for any
// future practice area (README §3/§6).
const paths: Record<IconName, string> = {
  // Car / collision
  injury:
    'M4 13l1.5-4.5A2 2 0 0 1 7.4 7h9.2a2 2 0 0 1 1.9 1.5L20 13m-16 0h16m-16 0v4h2m14-4v4h-2m-9 0h6M6.5 16.5h.01M17.5 16.5h.01',
  // Heart / family loss
  'wrongful-death':
    'M12 20s-7-4.35-9.5-8.5A4.5 4.5 0 0 1 12 6a4.5 4.5 0 0 1 9.5 5.5C19 15.65 12 20 12 20z',
  // Shield + check / insurance protection
  insurance:
    'M12 3l7 2.6v5.1c0 4.4-3 7.4-7 8.8-4-1.4-7-4.4-7-8.8V5.6L12 3z M9 11.6l2 2 4-4.2',
  // Briefcase / business
  business:
    'M4 8.5h16v10.5H4z M9 8.5V6.4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2.1 M4 13.2h16',
  // Signed document / contract
  contract:
    'M7 3h7l4 4v13H7V3z M14 3v4h4 M9.4 11h5.2 M9.4 14h5.2 M9.4 17.1c1-1.5 2 1.5 3 0s2 1 3-.5',
  // Two figures / family
  family:
    'M8 10.2a2.4 2.4 0 1 0 0-4.8 2.4 2.4 0 0 0 0 4.8z M3.6 19v-1.1a4.4 4.4 0 0 1 8.8 0V19 M16 10a2.2 2.2 0 1 0 0-4.4 M14.6 13.3a4 4 0 0 1 5.8 3.6V19',
  // Dollar in circle / consumer & debt
  'consumer-debt':
    'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z M12 6.8v10.4 M14.6 9c0-1.2-1.2-1.8-2.6-1.8s-2.6.7-2.6 1.9S12 12 12 12s2.6.3 2.6 1.9-1.2 1.9-2.6 1.9-2.6-.7-2.6-1.9',
  // Document / will
  estate:
    'M7 3h7l4 4v14H7V3zm7 0v4h4M9.5 12h5M9.5 15.5h5M9.5 8.5h2',
  // Courthouse columns / probate & guardianship
  probate:
    'M3.5 20.5h17 M4.5 20.5V10 M19.5 20.5V10 M3 10l9-5 9 5 M8 20.5V13 M12 20.5V13 M16 20.5V13',
  // Scales of justice / litigation
  litigation:
    'M12 3v18M7 21h10M5 7h14M8 7l-3 6a3 3 0 0 0 6 0l-3-6zm11 0l-3 6a3 3 0 0 0 6 0l-3-6zM12 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2z',
  // House / property
  landlord: 'M4 11l8-6 8 6M6 10v10h12V10M10 20v-6h4v6',
};
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="#CBB067"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={paths[name]} />
</svg>
