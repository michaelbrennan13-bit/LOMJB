---
import Layout from '../layouts/Layout.astro';
import PracticeIcon from '../components/PracticeIcon.astro';
import { SITE, COMPLIANCE } from '../consts';
import { PRACTICES } from '../data/practices';

const title = 'Practice Areas | Law Office of Michael J. Brennan, PLLC';
const description =
  'A full-service Texas firm led by personal injury: injury, wrongful death, insurance disputes, business, contracts, family law, consumer & debt defense, estate planning, probate, civil litigation, and real estate. Fort Bend County & Greater Houston.';
---

<Layout title={title} description={description} path="/practice-areas">
  <!-- Intro -->
  <section class="bg-white">
    <div class="container-page py-16 md:py-20">
      <p class="eyebrow">Practice Areas</p>
      <span class="gold-rule mt-4"></span>
      <h1 class="mt-5 max-w-3xl text-4xl font-bold text-navy md:text-5xl">
        Practical representation across the matters that affect Texas families.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-charcoal/90">
        Personal injury is a core focus, but the firm is full-service — from
        insurance disputes and business agreements to family law and estate
        planning. Whatever the matter, you get direct attorney access and clear,
        upfront fees.
      </p>
    </div>
  </section>

  <!-- Practice detail sections -->
  <div class="bg-white pb-8">
    <div class="container-page">
      {
        PRACTICES.map((p, i) => (
          <section
            id={p.slug}
            class="scroll-mt-28 border-t border-warmgrey py-14 first:border-t-0 md:grid md:grid-cols-[1fr_1.8fr] md:gap-12"
          >
            <div class="md:sticky md:top-28 md:self-start">
              <div class="flex items-center gap-3">
                <span class="inline-flex h-14 w-14 items-center justify-center rounded-full border-2 border-gold">
                  <PracticeIcon name={p.icon} class="h-7 w-7" />
                </span>
              </div>
              <h2 class="mt-5 text-2xl font-bold text-navy md:text-3xl">
                {p.title}
              </h2>
            </div>

            <div class="mt-6 md:mt-0">
              <p class="text-[17px] leading-relaxed text-charcoal/90">
                {p.detail}
              </p>

              {p.points && (
                <ul class="mt-6 grid gap-2 sm:grid-cols-2">
                  {p.points.map((pt) => (
                    <li class="flex items-start gap-2 text-[15px] text-charcoal/85">
                      <span
                        class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-gold"
                        aria-hidden="true"
                      />
                      {pt}
                    </li>
                  ))}
                </ul>
              )}

              {p.contingency && (
                <div class="mt-7 border-l-4 border-gold bg-warmgrey/60 p-6">
                  <p class="font-semibold text-navy">
                    No attorney’s fee unless we obtain a recovery for you.
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-charcoal/90">
                    {COMPLIANCE.contingencyCosts}
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-charcoal/80">
                    {COMPLIANCE.pastResults}
                  </p>
                </div>
              )}

              {p.contingencyOptional && (
                <div class="mt-7 border-l-4 border-gold bg-warmgrey/60 p-6">
                  <p class="font-semibold text-navy">
                    Contingency or hourly — depending on your matter.
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-charcoal/90">
                    {COMPLIANCE.contingencyOptionalNote}
                  </p>
                  <p class="mt-3 text-sm leading-relaxed text-charcoal/80">
                    {COMPLIANCE.pastResults}
                  </p>
                </div>
              )}

              {!p.contingency && !p.contingencyOptional && (
                <p class="mt-5 text-sm text-charcoal/70">
                  Consultations available. Fees are typically flat or hourly,
                  depending on the matter.
                </p>
              )}
            </div>
          </section>
        ))
      }
    </div>
  </div>

  <!-- CTA -->
  <section class="bg-navy text-white">
    <div class="container-page flex flex-col items-start gap-6 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl font-bold text-white md:text-4xl">
          Not sure where your matter fits? Ask.
        </h2>
        <p class="mt-3 text-white/85">{SITE.tagline}</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn btn-on-dark">Free Consultation</a>
        <a
          href={`tel:${SITE.phoneHref}`}
          class="btn border-2 border-white text-white hover:bg-white hover:text-navy"
        >
          Call {SITE.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
