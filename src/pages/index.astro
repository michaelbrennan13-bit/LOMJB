---
import Layout from '../layouts/Layout.astro';
import PracticeIcon from '../components/PracticeIcon.astro';
import { SITE, COMPLIANCE } from '../consts';
import { PRACTICES } from '../data/practices';

const title =
  'Fort Bend County Personal Injury Attorney | Law Office of Michael J. Brennan';
const description =
  'Full-service Texas law firm led by personal injury, serving Fort Bend County and Greater Houston. Work directly with your attorney — a former defense-side litigator now representing plaintiffs. Free consultation.';
---

<Layout title={title} description={description} path="/">
  <!-- ============================ HERO ============================ -->
  <section class="relative overflow-hidden bg-white">
    <!-- faint seal watermark -->
    <img
      src="/assets/brennan-mark.svg"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute -right-16 top-1/2 hidden w-[420px] -translate-y-1/2 opacity-[0.06] md:block"
    />
    <div class="container-page relative py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="eyebrow">Personal Injury &amp; Full-Service Practice</p>
        <span class="gold-rule mt-5"></span>
        <h1 class="font-display mt-6 text-4xl font-700 leading-tight text-navy sm:text-5xl md:text-6xl">
          When it matters most, you deserve a lawyer who picks up the phone.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-charcoal/90">
          Solo attention, straight answers, and deep Fort Bend roots. You work
          directly with your attorney — not a case manager — from the first call
          to resolution.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a href="/contact" class="btn btn-primary">Free Consultation</a>
          <a href={`tel:${SITE.phoneHref}`} class="btn btn-secondary">
            Call {SITE.phone}
          </a>
        </div>
        <p class="font-display mt-8 text-sm tracking-wide text-burgundy">
          {SITE.tagline}
        </p>
      </div>
    </div>
  </section>

  <!-- ======================= POSITIONING BAND ======================= -->
  <section class="bg-navy text-white">
    <div class="container-page py-16">
      <div class="max-w-4xl">
        <span class="gold-rule mb-6"></span>
        <p class="text-xl leading-relaxed md:text-2xl">
          You work directly with your attorney, not a case manager. Years spent
          defending corporations and insurers now sharpen the strategy on your
          side of the docket, and hands-on knowledge of Fort Bend and Harris
          County courts means practical, local guidance at every step.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================= PRACTICE AREAS ======================= -->
  <section class="bg-white">
    <div class="container-page py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">Practice Areas</p>
        <span class="gold-rule mt-4"></span>
        <h2 class="mt-5 text-3xl font-bold text-navy md:text-4xl">
          Focused help across the matters that affect Texas families.
        </h2>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          PRACTICES.map((p) => (
            <a
              href={`/practice-areas#${p.slug}`}
              class="group flex flex-col rounded-lg border border-warmgrey bg-white p-7 transition-shadow hover:shadow-lg"
            >
              <div class="flex items-center gap-3">
                <PracticeIcon name={p.icon} />
                {p.flagship && (
                  <span class="eyebrow !text-[0.65rem] !tracking-[0.18em] text-burgundy">
                    Flagship
                  </span>
                )}
              </div>
              <h3 class="mt-5 text-xl font-semibold text-navy group-hover:text-burgundy">
                {p.title}
              </h3>
              <p class="mt-3 text-[15px] leading-relaxed text-charcoal/85">
                {p.blurb}
              </p>
              <span class="mt-5 text-sm font-semibold text-burgundy">
                Learn more →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ========================= WHY THIS FIRM ========================= -->
  <section class="bg-warmgrey">
    <div class="container-page py-20">
      <div class="max-w-2xl">
        <p class="eyebrow">Why This Firm</p>
        <span class="gold-rule mt-4"></span>
      </div>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          [
            {
              t: 'Solo focus, direct access',
              d: 'Your case is handled by the attorney you hired. Call and you reach the person doing the work.',
            },
            {
              t: 'Local court knowledge',
              d: 'Familiarity with Fort Bend and Harris County courts and the way matters actually move here.',
            },
            {
              t: 'Clear, straightforward fees',
              d: 'Plain explanations of how fees work before you commit — no surprises, no runaround.',
            },
          ].map((v) => (
            <div class="border-t-2 border-gold bg-white p-8">
              <h3 class="text-xl font-semibold text-navy">{v.t}</h3>
              <p class="mt-3 leading-relaxed text-charcoal/85">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= CONTINGENCY BAND ======================= -->
  <section class="bg-white">
    <div class="container-page py-16">
      <div class="mx-auto max-w-3xl border-l-4 border-gold bg-warmgrey/60 p-8 md:p-10">
        <p class="text-2xl font-semibold text-navy md:text-3xl">
          No attorney’s fee unless we obtain a recovery for you.
        </p>
        <p class="mt-4 text-[15px] leading-relaxed text-charcoal/90">
          {COMPLIANCE.contingencyCosts}
        </p>
      </div>
    </div>
  </section>

  <!-- ============================ CTA ============================ -->
  <section class="bg-navy text-white">
    <div class="container-page flex flex-col items-start gap-6 py-16 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="text-3xl font-bold text-white md:text-4xl">
          Talk through your situation — free and confidential to start.
        </h2>
        <p class="mt-3 text-white/85">{SITE.tagline}</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a href="/contact" class="btn btn-on-dark">Free Consultation</a>
        <a
          href={`tel:${SITE.phoneHref}`}
          class="btn border-2 border-white text-white hover:bg-white hover:text-navy"
        >
          Call {SITE.phone}
        </a>
      </div>
    </div>
  </section>
</Layout>
